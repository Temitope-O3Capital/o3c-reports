# Supabase (Fallback DB)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# MSSQL (Primary DB via Cloudflare Tunnel)
MSSQL_SERVER=mssql.o3ccards.com
MSSQL_DATABASE=YOUR_DATABASE_NAME
MSSQL_TRUSTED=no
MSSQL_USER=your_sql_username
MSSQL_PASSWORD=your_sql_password

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string

# Sync Engine (office PC)
SYNC_ENGINE_URL=http://YOUR_OFFICE_IP:5001
