# ── Supabase (Fallback DB) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── MSSQL (Primary DB via Cloudflare Tunnel) ──────────────────────────────────
# Note: config.go reads MSSQL_DB (not MSSQL_DATABASE) for the database name
MSSQL_SERVER=mssql.o3ccards.com
MSSQL_DB=YOUR_DATABASE_NAME
MSSQL_TRUSTED=no
MSSQL_USER=your_sql_username
MSSQL_PASSWORD=your_sql_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-64-char-string

# Exactly 32 bytes — generate with: openssl rand -hex 16
ENCRYPTION_KEY=change-this-to-exactly-32-bytes-

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.pages.dev

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Sync Engine ───────────────────────────────────────────────────────────────
SYNC_ENGINE_URL=http://YOUR_OFFICE_IP:5001

# ── Admin Reset (set only when actively resetting a password, then remove) ────
# RESET_ADMIN_SECRET=change-to-a-secure-random-value
# ENABLE_RESET_ADMIN=true
