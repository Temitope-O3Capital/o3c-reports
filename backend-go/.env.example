# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres
# Optional: MSSQL connection for live data (leave blank for Supabase-only mode)
MSSQL_SERVER=
MSSQL_DB=
MSSQL_USER=
MSSQL_PASSWORD=
# Set to "yes" for Windows Integrated Auth (office domain machines only)
MSSQL_TRUSTED=

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-openssl-rand-hex-32
ENCRYPTION_KEY=replace-with-exactly-32-random-bytes
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.pages.dev
# Optional: require this header on POST /api/auth/bootstrap. Set before first deploy, remove after.
BOOTSTRAP_SECRET=

# ── App URL ──────────────────────────────────────────────────────────────────
# Required for campaign unsubscribe links (CAN-SPAM/NDPR compliance).
# Set to the public URL of the frontend, e.g. https://reports.o3cards.com
APP_BASE_URL=

# ── Mail / Messaging ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=care@o3capital.com
SENDGRID_FROM_NAME=Care
SENDGRID_REPLY_TO_EMAIL=care@o3capital.com
# Optional: SendGrid Inbound Parse domain for captured replies, e.g. replies.o3capital.com.
MAIL_INBOUND_DOMAIN=
# Prefer signed SendGrid Event Webhooks in production.
SENDGRID_WEBHOOK_PUBLIC_KEY=
# Dev fallback only, used when SENDGRID_WEBHOOK_PUBLIC_KEY is empty.
EMAIL_WEBHOOK_SECRET=
SMS_WEBHOOK_SECRET=

# Microsoft Graph is used for one-to-one staff mail so messages are saved to
# the staff user's Sent Items. The Entra app needs Mail.Send application permission.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# ── Africa's Talking Voice (Call Center) ─────────────────────────────────────
# See docs/AT_VOICE_SETUP.md for step-by-step setup instructions.
# AT_API_KEY and AT_USERNAME are required for the dialer to appear in the browser.
AT_API_KEY=
AT_USERNAME=
# The +234 virtual number you bought from the AT dashboard (e.g. +23417006001)
AT_PHONE_NUMBER=
# Real Nigerian mobile number to bridge inbound calls to (e.g. +2348012345678)
# This is the number that rings when a customer calls your AT_PHONE_NUMBER.
AT_AGENT_MOBILE=

# ── Zoho Voice (legacy SIP — kept for backward compat) ────────────────────────
# DC options: com | eu | in | com.au | jp | ca  (default: com)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_DC=com

# ── Paystack (Reconciliation) ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
# Optional: override default https://api.paystack.co
# PAYSTACK_BASE_URL=https://api.paystack.co

# ── Interswitch (Reconciliation) ──────────────────────────────────────────────
INTERSWITCH_CLIENT_ID=
INTERSWITCH_CLIENT_SECRET=
# Default: https://passport.interswitch.com/passport/oauth/token
INTERSWITCH_PASSPORT_URL=
# Base URL for transaction queries (set to your Interswitch API product URL)
INTERSWITCH_BASE_URL=
# Default transaction path: /api/v3/transactions
# INTERSWITCH_TRANSACTION_PATH=/api/v3/transactions
